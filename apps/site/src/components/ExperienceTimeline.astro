---
import { loadFacts } from '../lib/content';
const f = loadFacts();

function fmt(s: string): string {
  if (s === 'present') return 'Present';
  // Already a year-only entry like "2027"
  if (/^\d{4}$/.test(s)) return s;
  const [y, m] = s.split('-');
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  return `${months[parseInt(m, 10) - 1]} ${y}`;
}

const work = f.experience;
const edu = f.education;
---
<section class="career" id="career">
  <h2 class="section-title">Experience</h2>
  <ol class="timeline">
    {work.map((e) => (
      <li class="entry">
        <div class="entry-head">
          <span class="entry-dates">{fmt(e.start)} - {fmt(e.end)}</span>
          <h3 class="entry-role">{e.role}</h3>
          <span class="entry-place">{e.company}</span>
        </div>
        {e.bullets.length > 0 && (
          <ul class="entry-bullets">
            {e.bullets.slice(0, 2).map((b) => <li>{b}</li>)}
          </ul>
        )}
      </li>
    ))}
  </ol>

  <h2 class="section-title" style="margin-top: var(--space-xl)">Education</h2>
  <ol class="timeline timeline-edu">
    {edu.map((e) => (
      <li class="entry">
        <div class="entry-head">
          <span class="entry-dates">{fmt(e.start)} - {fmt(e.end)}</span>
          <h3 class="entry-role">{e.degree}</h3>
          <span class="entry-place">{e.school}</span>
        </div>
        {e.notes && <p class="entry-notes">{e.notes}</p>}
      </li>
    ))}
  </ol>
</section>

<style>
  .career {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .section-title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    margin: 0 0 var(--space-sm);
  }
  .timeline {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-left: var(--space-md);
    border-left: 1px solid var(--border);
  }
  .entry {
    position: relative;
  }
  .entry::before {
    content: "";
    position: absolute;
    left: calc(-1 * var(--space-md) - 4px);
    top: 6px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent-glow);
  }
  .entry-head {
    display: grid;
    grid-template-columns: 160px 1fr;
    column-gap: var(--space-md);
    align-items: baseline;
  }
  .entry-dates {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--fg-muted);
    letter-spacing: 0.02em;
    grid-row: 1 / span 2;
  }
  .entry-role {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    margin: 0;
    line-height: 1.3;
  }
  .entry-place {
    font-size: 13px;
    color: var(--fg-muted);
    line-height: 1.3;
  }
  .entry-bullets {
    margin: var(--space-xs) 0 0 200px;
    padding-left: var(--space-md);
    font-size: 13px;
    color: var(--fg);
    line-height: 1.55;
  }
  .entry-bullets li { margin-bottom: 2px; }
  .entry-notes {
    margin: var(--space-xs) 0 0 200px;
    font-size: 12px;
    color: var(--fg-muted);
    line-height: 1.5;
  }
  @media (max-width: 640px) {
    .entry-head {
      grid-template-columns: 1fr;
      row-gap: 2px;
    }
    .entry-dates { grid-row: auto; order: 2; }
    .entry-bullets, .entry-notes { margin-left: 0; }
  }
</style>
