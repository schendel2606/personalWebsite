---
import { loadFacts } from '../lib/content';
const f = loadFacts();
---
<section class="resume" id="resume">
  <h2 class="section-title">Resume</h2>
  <p class="section-hint">Pick the variant that fits your role.</p>
  <ul class="variants">
    {f.positioning.variants.map((v) => (
      <li>
        <a href={`/resumes/${encodeURI(v.file)}`} download>
          <span class="label">{v.label}</span>
          <span class="hint">PDF ↓</span>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .resume { display: flex; flex-direction: column; gap: var(--space-sm); }
  .section-title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    margin: 0;
  }
  .section-hint { color: var(--fg-muted); font-size: 12px; margin: 0; }
  .variants { list-style: none; display: flex; flex-direction: column; gap: 4px; }
  .variants a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px var(--space-md);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--fg);
    font-size: 13px;
    transition: border-color 120ms;
  }
  .variants a:hover { border-color: var(--accent); }
  .label { font-weight: 500; }
  .hint { font-family: var(--font-mono); font-size: 11px; color: var(--fg-muted); }
</style>
