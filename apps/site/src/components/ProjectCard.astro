---
import type { Project } from '../lib/content';
interface Props { project: Project; }
const { project } = Astro.props;
const visibleStack = project.stack.slice(0, 4);
const overflow = project.stack.length - visibleStack.length;
---
<article class="project-card">
  <header>
    <h3 class="project-title">{project.title}</h3>
    <p class="project-tagline">{project.tagline}</p>
  </header>
  <ul class="project-stack" aria-label="Stack">
    {visibleStack.map((s) => <li>{s}</li>)}
    {overflow > 0 && <li class="overflow">+{overflow}</li>}
  </ul>
  <footer class="project-links">
    {project.links.live && (
      <a href={project.links.live} target="_blank" rel="noopener" aria-label="Live site">live ↗</a>
    )}
    {project.links.repo && (
      <a href={project.links.repo} target="_blank" rel="noopener" aria-label="Repository">code ↗</a>
    )}
  </footer>
</article>

<style>
  .project-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-md) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition: border-color 120ms ease;
  }
  .project-card:hover { border-color: var(--accent); }
  .project-title {
    font-family: var(--font-mono);
    font-size: 15px;
    margin-bottom: 2px;
  }
  .project-tagline {
    color: var(--fg-muted);
    font-size: 13px;
    line-height: 1.4;
    margin: 0;
  }
  .project-stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .project-stack li {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 2px 7px;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    color: var(--fg-muted);
  }
  .project-stack li.overflow {
    color: var(--accent);
    border-color: rgba(94, 106, 210, 0.4);
  }
  .project-links {
    display: flex;
    gap: var(--space-md);
    font-family: var(--font-mono);
    font-size: 11px;
    margin-top: auto;
  }
  .project-links a { color: var(--fg-muted); }
  .project-links a:hover { color: var(--accent); }
</style>
