---
import type { Project } from '../lib/content';
interface Props { project: Project; }
const { project } = Astro.props;
const COMPACT_STACK_COUNT = 4;
const overflow = Math.max(0, project.stack.length - COMPACT_STACK_COUNT);
const liveHost = project.links.live ? new URL(project.links.live).host : null;
const stackToggleId = `stack-toggle-${project.id}`;
---
<article class="project-card">
  {/* Empty <details> drives an [open] sibling selector below for the body. */}
  <details class="card-toggle">
    <summary class="title-row">
      <h3 class="title">{project.title}</h3>
      <span class="chev" aria-hidden="true">▾</span>
    </summary>
  </details>

  <p class="tagline">{project.tagline}</p>

  {/* Hidden checkbox + label pattern for the stack overflow toggle.
      Zero JS, accessible (label is associated to the checkbox via for/id,
      checkbox is keyboard-focusable). */}
  <input type="checkbox" id={stackToggleId} class="stack-toggle" hidden />
  <ul class="stack" aria-label="Stack">
    {project.stack.map((s, i) => (
      <li class:list={['stack-tag', { 'stack-extra': i >= COMPACT_STACK_COUNT }]}>{s}</li>
    ))}
    {overflow > 0 && (
      <li class="stack-control">
        <label for={stackToggleId} class="overflow" aria-label={`Show ${overflow} more tags`}>
          <span class="overflow-collapsed">+{overflow}</span>
          <span class="overflow-expanded" aria-hidden="true">−</span>
        </label>
      </li>
    )}
  </ul>

  <div class="body" set:html={project.body} />

  <footer class="actions">
    {project.links.live && (
      <a
        class="action primary"
        href={project.links.live}
        target="_blank"
        rel="noopener"
        aria-label={`Open ${project.title} live site`}
      >
        Open {liveHost} ↗
      </a>
    )}
    {project.links.repo && (
      <a
        class="action secondary"
        href={project.links.repo}
        target="_blank"
        rel="noopener"
        aria-label={`${project.title} repository`}
      >
        Code ↗
      </a>
    )}
  </footer>
</article>

<style>
  .project-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-md) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition: border-color 120ms ease;
  }
  .project-card:hover { border-color: var(--accent); }

  /* Title disclosure (body toggle). */
  .card-toggle { margin: 0; }
  .card-toggle > summary { list-style: none; }
  .card-toggle > summary::-webkit-details-marker { display: none; }
  .title-row {
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    user-select: none;
  }
  .title {
    font-family: var(--font-mono);
    font-size: 15px;
    margin: 0;
    line-height: 1.2;
  }
  .chev {
    color: var(--fg-muted);
    font-size: 12px;
    transition: transform 180ms ease;
    display: inline-block;
  }
  .card-toggle[open] .chev { transform: rotate(180deg); color: var(--accent); }
  .title-row:hover .title { color: var(--accent); }

  .tagline {
    color: var(--fg-muted);
    font-size: 13px;
    line-height: 1.4;
    margin: 0;
  }

  /* Stack pills. */
  .stack {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    align-items: center;
  }
  .stack-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 2px 7px;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    color: var(--fg-muted);
  }
  .stack-extra { display: none; }
  .stack-toggle:checked ~ .stack .stack-extra { display: inline-flex; }

  /* +N chip. Becomes "−" when expanded. */
  .stack-control { list-style: none; }
  .overflow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    user-select: none;
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 2px 8px;
    border: 1px solid rgba(94, 106, 210, 0.4);
    border-radius: var(--radius-pill);
    color: var(--accent);
    background: transparent;
    transition: background 120ms ease, color 120ms ease;
    min-width: 26px;
  }
  .overflow:hover { background: rgba(94, 106, 210, 0.12); }
  .overflow:focus-within { outline: 2px solid var(--accent); outline-offset: 2px; }
  .stack-toggle:focus-visible + .stack .overflow { outline: 2px solid var(--accent); outline-offset: 2px; }
  .overflow-expanded { display: none; }
  .stack-toggle:checked ~ .stack .overflow-collapsed { display: none; }
  .stack-toggle:checked ~ .stack .overflow-expanded { display: inline; }

  /* Body: hidden by default, shown when title <details> is open. */
  .body {
    display: none;
    font-size: 13px;
    line-height: 1.6;
    color: var(--fg);
    padding-top: var(--space-xs);
    border-top: 1px solid var(--border);
  }
  .card-toggle[open] ~ .body { display: block; }
  .body :global(p) { margin-bottom: var(--space-sm); }
  .body :global(p:last-child) { margin-bottom: 0; }

  /* Actions footer. */
  .actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-top: 2px;
  }
  .action {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 6px 12px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: all 120ms ease;
    line-height: 1.2;
  }
  .action.primary {
    background: var(--accent);
    color: white;
    border: 1px solid var(--accent);
    font-weight: 500;
  }
  .action.primary:hover {
    background: rgba(94, 106, 210, 0.85);
    text-decoration: none;
  }
  .action.secondary {
    color: var(--fg-muted);
    border: 1px solid var(--border);
  }
  .action.secondary:hover {
    color: var(--accent);
    border-color: var(--accent);
    text-decoration: none;
  }
</style>
