---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ResumeDownloads from '../components/ResumeDownloads.astro';
import ExperienceTimeline from '../components/ExperienceTimeline.astro';
import ChatPanel from '../components/ChatPanel.tsx';
import { loadProjects } from '../lib/content';

const projects = loadProjects();
---
<BaseLayout>
  <main class="page">
    <Hero />

    <div class="grid">
      <div class="grid-chat">
        <ChatPanel client:visible />
      </div>

      <aside class="grid-side">
        <section class="projects">
          <h2 class="section-title">Personal Projects</h2>
          {projects.map((p) => <ProjectCard project={p} />)}
        </section>
        <ResumeDownloads />
      </aside>
    </div>

    <ExperienceTimeline />
  </main>
</BaseLayout>

<style>
  .page {
    max-width: var(--max-width-page);
    margin: 0 auto;
    padding: var(--space-xl) var(--space-lg);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }
  .grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
    gap: var(--space-xl);
    min-height: 480px;
  }
  .grid-chat { display: flex; }
  .grid-side {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    min-width: 0;
  }
  .projects {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }
  .section-title {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-muted);
    margin: 0 0 4px;
  }
  @media (max-width: 900px) {
    .grid { grid-template-columns: 1fr; }
    .grid-chat { order: 1; min-height: 520px; }
    .grid-side { order: 2; }
  }
  @media (max-width: 640px) {
    .page { padding: var(--space-md); gap: var(--space-lg); }
  }
</style>
